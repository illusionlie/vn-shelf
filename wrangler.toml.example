name = "__WORKER_NAME__"
main = "src/index.js"
compatibility_date = "2026-02-14"

# 禁用指标发送
send_metrics = false

# KV命名空间绑定
[[kv_namespaces]]
binding = "KV"   # 不要修改此项
id = "__KV_NAMESPACE_ID__"

# Queue生产者（批量索引）
[[queues.producers]]
queue = "vn-index-queue"
binding = "VN_INDEX_QUEUE" # 不要修改此项

# Queue消费者（批量索引处理）
[[queues.consumers]]
queue = "vn-index-queue"
max_batch_size = 1
max_batch_timeout = 1

# Durable Object 绑定（索引启动原子锁）
[[durable_objects.bindings]]
name = "INDEX_START_LOCK" # 不要修改此项
class_name = "IndexStartLockDurableObject"

[[migrations]]
tag = "v1"
new_sqlite_classes = ["IndexStartLockDurableObject"]

# Worker Assets 配置（静态资源）
[assets]
directory = "./public"
binding = "ASSETS" # 不要修改此项
html_handling = "auto-trailing-slash"

# 开启 observability
[observability]
enabled = true
head_sampling_rate = 1

# 环境变量
[vars]
ENVIRONMENT = "development"

# 生产环境配置
[env.production]
vars = { ENVIRONMENT = "production" }